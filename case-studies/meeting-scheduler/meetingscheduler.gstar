  <links xsi:type="gstar:Dependency" id="DP_4" name="SchedulerDependsOnNotificationService" depender="AG_SCHEDULER" dependee="ROLE_NOTIFY_SERVICE" dependum="DA_NOTIFY_AVAILABLE" dependerElmt="OP_SYS_NOTIFY" dependeeElmt="T_NOTIFY_DELIVER"/>
  <links xsi:type="gstar:Dependency" id="DP_5" name="SchedulerDependsOnRoomService" depender="AG_SCHEDULER" dependee="ROLE_ROOM_SERVICE" dependum="DA_ROOM_AVAILABLE" dependerElmt="OP_SYS_RESERVE_ROOM" dependeeElmt="T_ROOM_RESERVE"/>
  <links xsi:type="gstar:Dependency" id="DP_6" name="SchedulerDependsOnParticipantConfirmation" depender="AG_SCHEDULER" dependee="ROLE_PARTICIPANT" dependum="G_PART_CONFIRMED" dependerElmt="OP_SYS_CONFIRM_SLOT" dependeeElmt="T_PART_CONFIRM_SLOT"/>

  <links xsi:type="gstar:ANDRefinement" id="RF_SYS_AND_5A" parent="G_ROOM_RESERVED_SYS" children="OP_SYS_RESERVE_ROOM"/>

  <!-- FIXED: removed T_INIT_DECIDE_CANCEL from cancellation refinement -->
  <links xsi:type="gstar:ANDRefinement" id="RF_SYS_AND_7" parent="G_CANCELLED_SYS" children="OP_SYS_CANCEL"/>

  <links xsi:type="gstar:ANDRefinement" id="RF_PART_AND_1" parent="G_PART_CONFIRMED" children="T_PART_CONFIRM_SLOT OP_SYS_CONFIRM_SLOT"/>

  <links xsi:type="gstar:Qualifies" id="QLF_SYS_1" quality="Q_TIMELINESS_SYS" qualified="G_MEETING_SCHEDULED_SYS"/>
  <links xsi:type="gstar:Qualifies" id="QLF_SYS_2" quality="Q_PRIVACY_SYS" qualified="G_AVAIL_COLLECTED_SYS"/>
  <links xsi:type="gstar:Qualifies" id="QLF_SYS_3" quality="Q_FAIRNESS_SYS" qualified="G_SLOT_PROPOSED_SYS"/>

  <links xsi:type="gstar:Contribution" id="CTR_SYS_1" source="G_MEETING_SCHEDULED_SYS" target="Q_TIMELINESS_SYS" polarity="MAKE"/>
  <links xsi:type="gstar:Contribution" id="CTR_SYS_2" source="OP_SYS_TIMEOUT" target="Q_TIMELINESS_SYS" polarity="HURT"/>
  <links xsi:type="gstar:Contribution" id="CTR_SYS_3" source="OP_SYS_RECEIVE_AVAIL" target="Q_PRIVACY_SYS" polarity="HURT"/>
  <links xsi:type="gstar:Contribution" id="CTR_SYS_4" source="OP_SYS_PROPOSE_SLOT" target="Q_FAIRNESS_SYS" polarity="HELP"/>
  <links xsi:type="gstar:Contribution" id="CTR_SYS_5" source="G_SLOT_PROPOSED_SYS" target="Q_FAIRNESS_SYS" polarity="MAKE"/>


  <!-- ===================== SpecPro / Temporal Layer ===================== -->
  <temporalVariables id="TV_REQ_RECEIVED" name="requestReceivedVar" kind="INPUT" dataType="BOOL">
    <binding id="Q_TV_REQ" name="BindRequestReceived">
      <snapshot id="SN_TV_REQ" name="S_TV_REQ">
        <objVars id="OV_TV_REQ_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TV_REQ" name="requestReceivedEqTrueBind" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TV_REQ_L" name="m.requestReceived" var="OV_TV_REQ_M" attr="requestReceived"/>
        <right xsi:type="gstar:Const" id="E_TV_REQ_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </binding>
  </temporalVariables>
  <temporalVariables id="TV_AVAIL_COLLECTED" name="availCollectedVar" kind="INTERNAL" dataType="BOOL">
    <binding id="Q_TV_AC" name="BindAvailCollected">
      <snapshot id="SN_TV_AC" name="S_TV_AC">
        <objVars id="OV_TV_AC_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TV_AC" name="availCollectedEqTrueBind" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TV_AC_L" name="m.availCollected" var="OV_TV_AC_M" attr="availCollected"/>
        <right xsi:type="gstar:Const" id="E_TV_AC_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </binding>
  </temporalVariables>
  <temporalVariables id="TV_SLOT_PROPOSED" name="slotProposedVar" kind="OUTPUT" dataType="BOOL">
    <binding id="Q_TV_SP" name="BindSlotProposed">
      <snapshot id="SN_TV_SP" name="S_TV_SP">
        <objVars id="OV_TV_SP_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TV_SP" name="slotProposedEqTrueBind" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TV_SP_L" name="m.slotProposed" var="OV_TV_SP_M" attr="slotProposed"/>
        <right xsi:type="gstar:Const" id="E_TV_SP_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </binding>
  </temporalVariables>
  <temporalVariables id="TV_NOTIFIED" name="notifiedVar" kind="OUTPUT" dataType="BOOL">
    <binding id="Q_TV_NT" name="BindNotified">
      <snapshot id="SN_TV_NT" name="S_TV_NT">
        <objVars id="OV_TV_NT_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TV_NT" name="notifiedEqTrueBind" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TV_NT_L" name="m.notified" var="OV_TV_NT_M" attr="notified"/>
        <right xsi:type="gstar:Const" id="E_TV_NT_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </binding>
  </temporalVariables>
  <temporalVariables id="TV_SCHEDULED" name="scheduledVar" kind="OUTPUT" dataType="BOOL">
    <binding id="Q_TV_SC" name="BindScheduled">
      <snapshot id="SN_TV_SC" name="S_TV_SC">
        <objVars id="OV_TV_SC_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TV_SC" name="scheduledEqTrueBind" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TV_SC_L" name="m.scheduled" var="OV_TV_SC_M" attr="scheduled"/>
        <right xsi:type="gstar:Const" id="E_TV_SC_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </binding>
  </temporalVariables>
  <temporalVariables id="TV_CANCELLED" name="cancelledVar" kind="OUTPUT" dataType="BOOL">
    <binding id="Q_TV_CN" name="BindCancelled">
      <snapshot id="SN_TV_CN" name="S_TV_CN">
        <objVars id="OV_TV_CN_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TV_CN" name="cancelledEqTrueBind" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TV_CN_L" name="m.cancelled" var="OV_TV_CN_M" attr="cancelled"/>
        <right xsi:type="gstar:Const" id="E_TV_CN_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </binding>
  </temporalVariables>

  <temporalRequirements id="TR_MEETING_EVENTUALLY_SCHEDULED" name="EventuallyScheduleMeeting" kind="EVENTUALITY" scope="GLOBAL" pattern="Existence" component="MeetingScheduler" formalism="SpecPro+LTL" fretishText="Globally, once a request is received, the meeting shall eventually be scheduled." ltlText="G(requestReceived -> F scheduled)">
    <trigger id="Q_TR_1" name="TriggerRequestReceived">
      <snapshot id="SN_TR_1" name="S_TR_1">
        <objVars id="OV_TR_1_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TR_1" name="requestReceivedEqTrueTR" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TR_1_L" name="m.requestReceived" var="OV_TR_1_M" attr="requestReceived"/>
        <right xsi:type="gstar:Const" id="E_TR_1_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </trigger>
    <response id="Q_RP_1" name="ResponseScheduled">
      <snapshot id="SN_RP_1" name="S_RP_1">
        <objVars id="OV_RP_1_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_RP_1" name="scheduledEqTrueTR" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_RP_1_L" name="m.scheduled" var="OV_RP_1_M" attr="scheduled"/>
        <right xsi:type="gstar:Const" id="E_RP_1_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </response>
  </temporalRequirements>

  <temporalRequirements id="TR_REQUEST_TO_AVAIL_REQUEST" name="RequestLeadsToAvailabilityRequest" kind="RESPONSE" scope="GLOBAL" pattern="Response" component="MeetingScheduler" formalism="SpecPro+LTL" fretishText="Globally, if a request is received, the system shall eventually send an availability request." ltlText="G(requestReceived -> F availRequestSent)">
    <trigger id="Q_TR_2" name="TriggerRequestReceived2">
      <snapshot id="SN_TR_2" name="S_TR_2">
        <objVars id="OV_TR_2_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TR_2" name="requestReceivedEqTrueTR2" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TR_2_L" name="m.requestReceived" var="OV_TR_2_M" attr="requestReceived"/>
        <right xsi:type="gstar:Const" id="E_TR_2_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </trigger>
    <response id="Q_RP_2" name="ResponseAvailRequestSent">
      <snapshot id="SN_RP_2" name="S_RP_2">
        <objVars id="OV_RP_2_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_RP_2" name="availRequestSentEqTrueTR" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_RP_2_L" name="m.availRequestSent" var="OV_RP_2_M" attr="availRequestSent"/>
        <right xsi:type="gstar:Const" id="E_RP_2_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </response>
  </temporalRequirements>

  <temporalRequirements id="TR_AVAIL_TO_PROPOSAL" name="AvailabilityCollectedLeadsToProposal" kind="RESPONSE" scope="GLOBAL" pattern="Response" component="MeetingScheduler" formalism="SpecPro+LTL" fretishText="Globally, if availability is collected, the system shall eventually propose a candidate slot." ltlText="G(availCollected -> F slotProposed)">
    <trigger id="Q_TR_3" name="TriggerAvailCollected">
      <snapshot id="SN_TR_3" name="S_TR_3">
        <objVars id="OV_TR_3_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TR_3" name="availCollectedEqTrueTR" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TR_3_L" name="m.availCollected" var="OV_TR_3_M" attr="availCollected"/>
        <right xsi:type="gstar:Const" id="E_TR_3_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </trigger>
    <response id="Q_RP_3" name="ResponseSlotProposed">
      <snapshot id="SN_RP_3" name="S_RP_3">
        <objVars id="OV_RP_3_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_RP_3" name="slotProposedEqTrueTR" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_RP_3_L" name="m.slotProposed" var="OV_RP_3_M" attr="slotProposed"/>
        <right xsi:type="gstar:Const" id="E_RP_3_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </response>
  </temporalRequirements>

  <temporalRequirements id="TR_PROPOSAL_TO_NOTIFICATION" name="ProposalLeadsToNotification" kind="RESPONSE" scope="GLOBAL" pattern="Response" component="MeetingScheduler" formalism="SpecPro+LTL" fretishText="Globally, if a candidate slot is proposed, the system shall eventually notify all participants." ltlText="G(slotProposed -> F notified)">
    <trigger id="Q_TR_4" name="TriggerSlotProposed">
      <snapshot id="SN_TR_4" name="S_TR_4">
        <objVars id="OV_TR_4_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_TR_4" name="slotProposedEqTrueTR2" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_TR_4_L" name="m.slotProposed" var="OV_TR_4_M" attr="slotProposed"/>
        <right xsi:type="gstar:Const" id="E_TR_4_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </trigger>
    <response id="Q_RP_4" name="ResponseNotified">
      <snapshot id="SN_RP_4" name="S_RP_4">
        <objVars id="OV_RP_4_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_RP_4" name="notifiedEqTrueTR" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_RP_4_L" name="m.notified" var="OV_RP_4_M" attr="notified"/>
        <right xsi:type="gstar:Const" id="E_RP_4_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </response>
  </temporalRequirements>

  <temporalRequirements id="TR_NEVER_SCHEDULED_AND_CANCELLED" name="NeverScheduledAndCancelledTogether" kind="INVARIANCE" scope="GLOBAL" pattern="Universality" component="MeetingScheduler" formalism="SpecPro+LTL" fretishText="Globally, it shall never be the case that a meeting is both scheduled and cancelled." ltlText="G(!(scheduled &amp;&amp; cancelled))">
    <statePredicate id="Q_ST_1" name="StateNotScheduledAndCancelled">
      <snapshot id="SN_ST_1" name="S_ST_1">
        <objVars id="OV_ST_1_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:Not" id="E_ST_1" name="notBothScheduledCancelled">
        <operand xsi:type="gstar:And" id="E_ST_1_IN" name="scheduledAndCancelled">
          <left xsi:type="gstar:RelOp" id="E_ST_1_L" name="scheduledEqTrueState" op="EQ">
            <left xsi:type="gstar:AttrRef" id="E_ST_1_LL" name="m.scheduled" var="OV_ST_1_M" attr="scheduled"/>
            <right xsi:type="gstar:Const" id="E_ST_1_LR" name="TRUE" type="BOOL" literal="TRUE"/>
          </left>
          <right xsi:type="gstar:RelOp" id="E_ST_1_R" name="cancelledEqTrueState" op="EQ">
            <left xsi:type="gstar:AttrRef" id="E_ST_1_RL" name="m.cancelled" var="OV_ST_1_M" attr="cancelled"/>
            <right xsi:type="gstar:Const" id="E_ST_1_RR" name="TRUE" type="BOOL" literal="TRUE"/>
          </right>
        </operand>
      </expr>
    </statePredicate>
  </temporalRequirements>

  <temporalRequirements id="TR_PARTICIPANT_RESPONSE_ASSUMPTION" name="ParticipantsEventuallyRespondAssumption" kind="ASSUMPTION" scope="GLOBAL" pattern="Assumption" component="Environment" formalism="SpecPro+LTL" fretishText="Assume globally that participant responses do not time out indefinitely." ltlText="G(!responseTimeout)">
    <statePredicate id="Q_ST_2" name="StateNoResponseTimeout">
      <snapshot id="SN_ST_2" name="S_ST_2">
        <objVars id="OV_ST_2_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_ST_2" name="responseTimeoutEqFalseState" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_ST_2_L" name="m.responseTimeout" var="OV_ST_2_M" attr="responseTimeout"/>
        <right xsi:type="gstar:Const" id="E_ST_2_R" name="FALSE" type="BOOL" literal="FALSE"/>
      </expr>
    </statePredicate>
  </temporalRequirements>

  <temporalLinks id="TL_1" role="DEFINES" source="G_MEETING_SCHEDULED_SYS" requirement="TR_MEETING_EVENTUALLY_SCHEDULED"/>
  <temporalLinks id="TL_2" role="OPERATIONALIZES" source="OP_SYS_SEND_AVAIL_REQUEST" requirement="TR_REQUEST_TO_AVAIL_REQUEST"/>
  <temporalLinks id="TL_3" role="DEFINES" source="G_AVAIL_COLLECTED_SYS" requirement="TR_AVAIL_TO_PROPOSAL"/>
  <temporalLinks id="TL_4" role="OPERATIONALIZES" source="OP_SYS_PROPOSE_SLOT" requirement="TR_AVAIL_TO_PROPOSAL"/>
  <temporalLinks id="TL_5" role="DEFINES" source="G_NOTIFIED_SYS" requirement="TR_PROPOSAL_TO_NOTIFICATION"/>
  <temporalLinks id="TL_6" role="OPERATIONALIZES" source="OP_SYS_NOTIFY" requirement="TR_PROPOSAL_TO_NOTIFICATION"/>
  <temporalLinks id="TL_7" role="CONSTRAINS" source="G_MEETING_SCHEDULED_SYS" requirement="TR_NEVER_SCHEDULED_AND_CANCELLED"/>
  <temporalLinks id="TL_8" role="CONSTRAINS" source="G_CANCELLED_SYS" requirement="TR_NEVER_SCHEDULED_AND_CANCELLED"/>
  <temporalLinks id="TL_9" role="ASSUMES" source="DA_CAL_AVAILABLE" requirement="TR_PARTICIPANT_RESPONSE_ASSUMPTION"/>

</gstar:GStarModel>
