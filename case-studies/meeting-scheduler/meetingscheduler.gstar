          <left xsi:type="gstar:AttrRef" id="E_PRE_CONF_1_L" name="m.notified" var="OV_PRE_CONF_M" attr="notified"/>
          <right xsi:type="gstar:Const" id="E_PRE_CONF_1_R" name="TRUE" type="BOOL" literal="TRUE"/>
        </left>
        <right xsi:type="gstar:RelOp" id="E_PRE_CONF_2" name="participantConfirmedEqTrue2" op="EQ">
          <left xsi:type="gstar:AttrRef" id="E_PRE_CONF_2_L" name="m.participantConfirmed" var="OV_PRE_CONF_M" attr="participantConfirmed"/>
          <right xsi:type="gstar:Const" id="E_PRE_CONF_2_R" name="TRUE" type="BOOL" literal="TRUE"/>
