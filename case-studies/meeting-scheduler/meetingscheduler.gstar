<?xml version="1.0" encoding="UTF-8"?>
<gstar:GStarModel
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:gstar="http://example.org/gstar">
  <nodes xsi:type="gstar:Role" id="ROLE_INITIATOR" name="Meeting Initiator"/>
  <nodes xsi:type="gstar:Role" id="ROLE_PARTICIPANT" name="Participant"/>
  <nodes xsi:type="gstar:Agent" id="AG_SCHEDULER" name="Meeting Scheduler System" isEnv="false"/>
  <nodes xsi:type="gstar:Role" id="ROLE_CAL_SERVICE" name="Calendar Service"/>
  <nodes xsi:type="gstar:Role" id="ROLE_NOTIFY_SERVICE" name="Notification Service"/>
  <nodes xsi:type="gstar:Role" id="ROLE_ROOM_SERVICE" name="Room Booking Service"/>
  <nodes xsi:type="gstar:Agent" id="AG_ALICE" name="Alice (Initiator)"/>
  <nodes xsi:type="gstar:Agent" id="AG_BOB" name="Bob (Participant)"/>
  <nodes xsi:type="gstar:Agent" id="AG_CAROL" name="Carol (Participant)"/>
  <nodes xsi:type="gstar:Agent" id="AG_DAVE" name="Dave (Participant)"/>
  <links xsi:type="gstar:ParticipatesIn" id="L_PART_1" name="Alice plays Initiator role" inner="AG_ALICE" outer="ROLE_INITIATOR"/>
  <links xsi:type="gstar:ParticipatesIn" id="L_PART_2" name="Bob plays Participant role" inner="AG_BOB" outer="ROLE_PARTICIPANT"/>
  <links xsi:type="gstar:ParticipatesIn" id="L_PART_3" name="Carol plays Participant role" inner="AG_CAROL" outer="ROLE_PARTICIPANT"/>
  <links xsi:type="gstar:ParticipatesIn" id="L_PART_4" name="Dave plays Participant role" inner="AG_DAVE" outer="ROLE_PARTICIPANT"/>
  <nodes xsi:type="gstar:Goal" id="G_MEETING_SCHEDULED_SYS" name="Meeting Be Scheduled" mode="ACHIEVE">
    <spec id="Q_GMS" name="Spec MeetingScheduled">
      <snapshot id="SN_GMS" name="S_GMS">
        <objVars id="OV_GMS_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GMS" name="scheduledEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GMS_L" name="m.scheduled" var="OV_GMS_M" attr="scheduled"/>
        <right xsi:type="gstar:Const" id="E_GMS_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_REQUEST_REGISTERED_SYS" name="Request Registered" mode="ACHIEVE">
    <spec id="Q_GRR" name="Spec RequestReceived">
      <snapshot id="SN_GRR" name="S_GRR">
        <objVars id="OV_GRR_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GRR" name="requestReceivedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GRR_L" name="m.requestReceived" var="OV_GRR_M" attr="requestReceived"/>
        <right xsi:type="gstar:Const" id="E_GRR_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_AVAIL_COLLECTED_SYS" name="Availability Collected" mode="ACHIEVE">
    <spec id="Q_GAC" name="Spec AvailCollected">
      <snapshot id="SN_GAC" name="S_GAC">
        <objVars id="OV_GAC_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GAC" name="availCollectedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GAC_L" name="m.availCollected" var="OV_GAC_M" attr="availCollected"/>
        <right xsi:type="gstar:Const" id="E_GAC_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_SLOT_PROPOSED_SYS" name="Candidate Slot Proposed" mode="ACHIEVE">
    <spec id="Q_GSP" name="Spec SlotProposed">
      <snapshot id="SN_GSP" name="S_GSP">
        <objVars id="OV_GSP_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GSP" name="slotProposedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GSP_L" name="m.slotProposed" var="OV_GSP_M" attr="slotProposed"/>
        <right xsi:type="gstar:Const" id="E_GSP_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_ROOM_RESERVED_SYS" name="Room Reserved" mode="ACHIEVE">
    <spec id="Q_GRM" name="Spec RoomReserved">
      <snapshot id="SN_GRM" name="S_GRM">
        <objVars id="OV_GRM_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GRM" name="roomReservedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GRM_L" name="m.roomReserved" var="OV_GRM_M" attr="roomReserved"/>
        <right xsi:type="gstar:Const" id="E_GRM_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_NOTIFIED_SYS" name="All Participants Notified" mode="ACHIEVE">
    <spec id="Q_GNT" name="Spec Notified">
      <snapshot id="SN_GNT" name="S_GNT">
        <objVars id="OV_GNT_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GNT" name="notifiedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GNT_L" name="m.notified" var="OV_GNT_M" attr="notified"/>
        <right xsi:type="gstar:Const" id="E_GNT_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_RESCHEDULE_REQUESTED_SYS" name="Reschedule Requested" mode="ACHIEVE">
    <spec id="Q_GRS" name="Spec RescheduleRequested">
      <snapshot id="SN_GRS" name="S_GRS">
        <objVars id="OV_GRS_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GRS" name="rescheduleRequestedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GRS_L" name="m.rescheduleRequested" var="OV_GRS_M" attr="rescheduleRequested"/>
        <right xsi:type="gstar:Const" id="E_GRS_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_CANCELLED_SYS" name="Meeting Cancelled" mode="ACHIEVE">
    <spec id="Q_GCN" name="Spec Cancelled">
      <snapshot id="SN_GCN" name="S_GCN">
        <objVars id="OV_GCN_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GCN" name="cancelledEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GCN_L" name="m.cancelled" var="OV_GCN_M" attr="cancelled"/>
        <right xsi:type="gstar:Const" id="E_GCN_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_INIT_REQUESTED" name="Request Initiated" mode="ACHIEVE">
    <spec id="Q_GIR" name="Spec RequestInitiated">
      <snapshot id="SN_GIR" name="S_GIR">
        <objVars id="OV_GIR_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GIR" name="requestInitiatedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GIR_L" name="m.requestInitiated" var="OV_GIR_M" attr="requestInitiated"/>
        <right xsi:type="gstar:Const" id="E_GIR_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Goal" id="G_PART_CONFIRMED" name="Slot Confirmed By Participant" mode="ACHIEVE">
    <spec id="Q_GPC" name="Spec ParticipantConfirmed">
      <snapshot id="SN_GPC" name="S_GPC">
        <objVars id="OV_GPC_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_GPC" name="participantConfirmedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_GPC_L" name="m.participantConfirmed" var="OV_GPC_M" attr="participantConfirmed"/>
        <right xsi:type="gstar:Const" id="E_GPC_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Quality" id="Q_TIMELINESS_SYS" name="Timeliness">
    <spec id="Q_QT" name="Spec Timeliness">
      <snapshot id="SN_QT" name="S_QT">
        <objVars id="OV_QT_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_QT" name="latencyLe60" op="LE">
        <left xsi:type="gstar:AttrRef" id="E_QT_L" name="m.decisionLatencySeconds" var="OV_QT_M" attr="decisionLatencySeconds"/>
        <right xsi:type="gstar:Const" id="E_QT_R" name="60" type="INT" literal="60"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Quality" id="Q_PRIVACY_SYS" name="Privacy">
    <spec id="Q_QP" name="Spec Privacy">
      <snapshot id="SN_QP" name="S_QP">
        <objVars id="OV_QP_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_QP" name="consentGivenEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_QP_L" name="m.consentGiven" var="OV_QP_M" attr="consentGiven"/>
        <right xsi:type="gstar:Const" id="E_QP_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Quality" id="Q_FAIRNESS_SYS" name="Fairness">
    <spec id="Q_QF" name="Spec Fairness">
      <snapshot id="SN_QF" name="S_QF">
        <objVars id="OV_QF_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_QF" name="fairnessGe80" op="GE">
        <left xsi:type="gstar:AttrRef" id="E_QF_L" name="m.fairnessScore" var="OV_QF_M" attr="fairnessScore"/>
        <right xsi:type="gstar:Const" id="E_QF_R" name="80" type="INT" literal="80"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:DomainAssumption" id="DA_CAL_AVAILABLE" name="Calendar Service Available">
    <spec id="Q_DA_CAL" name="Spec CalendarConnected">
      <snapshot id="SN_DA_CAL" name="S_DA_CAL">
        <objVars id="OV_DA_CAL_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_DA_CAL" name="calendarConnectedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_DA_CAL_L" name="m.calendarConnected" var="OV_DA_CAL_M" attr="calendarConnected"/>
        <right xsi:type="gstar:Const" id="E_DA_CAL_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:DomainAssumption" id="DA_NOTIFY_AVAILABLE" name="Notification Service Available">
    <spec id="Q_DA_NT" name="Spec NotifyConnected">
      <snapshot id="SN_DA_NT" name="S_DA_NT">
        <objVars id="OV_DA_NT_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_DA_NT" name="notifyConnectedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_DA_NT_L" name="m.notifyConnected" var="OV_DA_NT_M" attr="notifyConnected"/>
        <right xsi:type="gstar:Const" id="E_DA_NT_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:DomainAssumption" id="DA_ROOM_AVAILABLE" name="Room Service Available">
    <spec id="Q_DA_RM" name="Spec RoomServiceConnected">
      <snapshot id="SN_DA_RM" name="S_DA_RM">
        <objVars id="OV_DA_RM_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_DA_RM" name="roomServiceConnectedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_DA_RM_L" name="m.roomServiceConnected" var="OV_DA_RM_M" attr="roomServiceConnected"/>
        <right xsi:type="gstar:Const" id="E_DA_RM_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Obstacle" id="OB_NO_RESPONSE" name="No Participant Response" severity="6">
    <spec id="Q_OB_NR" name="Spec NoResponse">
      <snapshot id="SN_OB_NR" name="S_OB_NR">
        <objVars id="OV_OB_NR_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_OB_NR" name="responseTimeoutEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_OB_NR_L" name="m.responseTimeout" var="OV_OB_NR_M" attr="responseTimeout"/>
        <right xsi:type="gstar:Const" id="E_OB_NR_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Obstacle" id="OB_NO_COMMON_SLOT" name="No Common Slot" severity="7">
    <spec id="Q_OB_NS" name="Spec NoCommonSlot">
      <snapshot id="SN_OB_NS" name="S_OB_NS">
        <objVars id="OV_OB_NS_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_OB_NS" name="intersectionNonEmptyEqFalse" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_OB_NS_L" name="m.intersectionNonEmpty" var="OV_OB_NS_M" attr="intersectionNonEmpty"/>
        <right xsi:type="gstar:Const" id="E_OB_NS_R" name="FALSE" type="BOOL" literal="FALSE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Obstacle" id="OB_CAL_DOWN" name="Calendar Service Down" severity="8">
    <spec id="Q_OB_CD" name="Spec CalendarDown">
      <snapshot id="SN_OB_CD" name="S_OB_CD">
        <objVars id="OV_OB_CD_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_OB_CD" name="calendarConnectedEqFalse" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_OB_CD_L" name="m.calendarConnected" var="OV_OB_CD_M" attr="calendarConnected"/>
        <right xsi:type="gstar:Const" id="E_OB_CD_R" name="FALSE" type="BOOL" literal="FALSE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Obstacle" id="OB_ROOM_UNAVAILABLE" name="Room Unavailable" severity="6">
    <spec id="Q_OB_RU" name="Spec RoomUnavailable">
      <snapshot id="SN_OB_RU" name="S_OB_RU">
        <objVars id="OV_OB_RU_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_OB_RU" name="roomAvailableEqFalse" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_OB_RU_L" name="m.roomAvailable" var="OV_OB_RU_M" attr="roomAvailable"/>
        <right xsi:type="gstar:Const" id="E_OB_RU_R" name="FALSE" type="BOOL" literal="FALSE"/>
      </expr>
    </spec>
  </nodes>
  <nodes xsi:type="gstar:Task" id="T_INIT_CREATE_REQUEST" name="Create Meeting Request"/>
  <nodes xsi:type="gstar:Task" id="T_INIT_SELECT_RANGE" name="Select Candidate Date Range"/>
  <nodes xsi:type="gstar:Task" id="T_INIT_SEND_INVITES" name="Send Invitations"/>
  <!-- REMOVED: T_INIT_DECIDE_CANCEL -->
  <nodes xsi:type="gstar:Task" id="T_PART_CHECK_CAL" name="Check Calendar"/>
  <nodes xsi:type="gstar:Task" id="T_PART_SEND_AVAIL" name="Send Availability"/>
  <nodes xsi:type="gstar:Task" id="T_PART_CONFIRM_SLOT" name="Confirm Proposed Slot"/>
  <nodes xsi:type="gstar:Task" id="T_CAL_PROVIDE_STATUS" name="Provide Calendar Status"/>
  <nodes xsi:type="gstar:Task" id="T_NOTIFY_DELIVER" name="Deliver Notifications"/>
  <nodes xsi:type="gstar:Task" id="T_ROOM_RESERVE" name="Reserve Room"/>
  <nodes xsi:type="gstar:Resource" id="R_ATTENDEE_LIST" name="Attendee List" resourceType="data"/>
  <nodes xsi:type="gstar:Resource" id="R_DATE_RANGE" name="Preferred Date Range" resourceType="data"/>
  <nodes xsi:type="gstar:Resource" id="R_PART_AVAILABILITY" name="Availability Information" resourceType="data"/>
  <nodes xsi:type="gstar:Resource" id="R_PROPOSED_SLOT" name="Proposed Slot" resourceType="data"/>
  <nodes xsi:type="gstar:Resource" id="R_ROOM_RESERVATION" name="Room Reservation" resourceType="record"/>
  <nodes xsi:type="gstar:Resource" id="R_NOTIFICATION_LOG" name="Notification Log" resourceType="record"/>
  <nodes xsi:type="gstar:Operation" id="OP_SYS_ACCEPT_REQ" name="Accept Request">
    <preCondition id="Q_PRE_ACC" name="Pre AcceptReq">
      <snapshot id="SN_PRE_ACC" name="S_PRE_ACC">
        <objVars id="OV_PRE_ACC_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:Const" id="E_PRE_ACC" name="TRUE" type="BOOL" literal="TRUE"/>
    </preCondition>
    <postCondition id="Q_POST_ACC" name="Post AcceptReq">
      <snapshot id="SN_POST_ACC" name="S_POST_ACC">
        <objVars id="OV_POST_ACC_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_POST_ACC" name="requestReceivedPrimeEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_POST_ACC_L" name="m.requestReceivedPrime" var="OV_POST_ACC_M" attr="requestReceived" isPrime="true"/>
        <right xsi:type="gstar:Const" id="E_POST_ACC_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </postCondition>
    <modifies id="MOD_ACC_1" name="modRequestReceived" var="OV_POST_ACC_M" attr="requestReceived"/>
  </nodes>
  <nodes xsi:type="gstar:Operation" id="OP_SYS_SEND_AVAIL_REQUEST" name="Send Availability Request">
    <preCondition id="Q_PRE_SAR" name="Pre SendAvailRequest">
      <snapshot id="SN_PRE_SAR" name="S_PRE_SAR">
        <objVars id="OV_PRE_SAR_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_PRE_SAR" name="requestReceivedEqTrue2" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_PRE_SAR_L" name="m.requestReceived" var="OV_PRE_SAR_M" attr="requestReceived"/>
        <right xsi:type="gstar:Const" id="E_PRE_SAR_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </preCondition>
    <postCondition id="Q_POST_SAR" name="Post SendAvailRequest">
      <snapshot id="SN_POST_SAR" name="S_POST_SAR">
        <objVars id="OV_POST_SAR_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_POST_SAR" name="availRequestSentPrimeEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_POST_SAR_L" name="m.availRequestSentPrime" var="OV_POST_SAR_M" attr="availRequestSent" isPrime="true"/>
        <right xsi:type="gstar:Const" id="E_POST_SAR_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </postCondition>
    <modifies id="MOD_SAR_1" name="modAvailRequestSent" var="OV_POST_SAR_M" attr="availRequestSent"/>
  </nodes>
  <nodes xsi:type="gstar:Operation" id="OP_SYS_RECEIVE_AVAIL" name="Receive Availability">
    <preCondition id="Q_PRE_RAV" name="Pre ReceiveAvail">
      <snapshot id="SN_PRE_RAV" name="S_PRE_RAV">
        <objVars id="OV_PRE_RAV_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_PRE_RAV" name="availRequestSentEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_PRE_RAV_L" name="m.availRequestSent" var="OV_PRE_RAV_M" attr="availRequestSent"/>
        <right xsi:type="gstar:Const" id="E_PRE_RAV_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </preCondition>
    <postCondition id="Q_POST_RAV" name="Post ReceiveAvail">
      <snapshot id="SN_POST_RAV" name="S_POST_RAV">
        <objVars id="OV_POST_RAV_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_POST_RAV" name="availReceivedPrimeEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_POST_RAV_L" name="m.availReceivedPrime" var="OV_POST_RAV_M" attr="availReceived" isPrime="true"/>
        <right xsi:type="gstar:Const" id="E_POST_RAV_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </postCondition>
    <modifies id="MOD_RAV_1" name="modAvailReceived" var="OV_POST_RAV_M" attr="availReceived"/>
  </nodes>
  <nodes xsi:type="gstar:Operation" id="OP_SYS_MARK_AVAIL_COLLECTED" name="Mark Availability Collected">
    <preCondition id="Q_PRE_MAC" name="Pre MarkAvailCollected">
      <snapshot id="SN_PRE_MAC" name="S_PRE_MAC">
        <objVars id="OV_PRE_MAC_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_PRE_MAC" name="availReceivedEqTrue" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_PRE_MAC_L" name="m.availReceived" var="OV_PRE_MAC_M" attr="availReceived"/>
        <right xsi:type="gstar:Const" id="E_PRE_MAC_R" name="TRUE" type="BOOL" literal="TRUE"/>
      </expr>
    </preCondition>
    <postCondition id="Q_POST_MAC" name="Post MarkAvailCollected">
      <snapshot id="SN_POST_MAC" name="S_POST_MAC">
        <objVars id="OV_POST_MAC_M" name="m" varName="m" type="Meeting"/>
      </snapshot>
      <expr xsi:type="gstar:RelOp" id="E_POST_MAC" name="availCollectedPrimeEqTrue2" op="EQ">
        <left xsi:type="gstar:AttrRef" id="E_POST_MAC_L" name="m.availCollectedPrime" var="OV_POST_MAC_M" attr="availCollected" isPrime="true"/>
        <right xsi:type="gstar:Const" id="E_POST_MAC_R" name="TRUE" type="BOOL" literal="TRUE"/>
